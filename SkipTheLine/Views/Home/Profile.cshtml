@{
    ViewData["Title"] = "Profile - SkipTheLine";
}

<div style="max-width: 600px; margin: 0 auto; padding: 40px 20px;">
    <div class="card" style="padding: 40px;">
        <h2 style="text-align: center; margin-bottom: 30px;">My Profile</h2>

        <div id="errorMessage" class="alert alert-error" style="display: none;"></div>
        <div id="successMessage" class="alert alert-success" style="display: none;"></div>

        <div id="profileForm">
            <div class="form-group">
                <label>First Name</label>
                <input type="text" id="firstName" class="form-control">
            </div>
            <div class="form-group">
                <label>Last Name</label>
                <input type="text" id="lastName" class="form-control">
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" class="form-control" readonly>
            </div>
            <div class="form-group">
                <label>Phone Number</label>
                <input type="tel" id="phoneNumber" class="form-control">
            </div>
            <div class="form-group">
                <label>Dietary Preferences</label>
                <textarea id="dietaryPreferences" class="form-control" rows="3" placeholder="Any dietary restrictions?"></textarea>
            </div>
            <button id="updateBtn" class="btn btn-primary" style="width: 100%;">Update Profile</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const token = localStorage.getItem('token');

        if (!token) {
            window.location.href = '/Home/Login';
        }

        async function loadProfile() {
            try {
                const response = await fetch('/api/users/profile', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const user = await response.json();

                $('#firstName').val(user.firstName);
                $('#lastName').val(user.lastName);
                $('#email').val(user.email);
                $('#phoneNumber').val(user.phoneNumber);
                $('#dietaryPreferences').val(user.dietaryPreferences || '');
            } catch (error) {
                $('#errorMessage').text('Error loading profile').show();
            }
        }

        async function updateProfile() {
            const data = {
                firstName: $('#firstName').val(),
                lastName: $('#lastName').val(),
                phoneNumber: $('#phoneNumber').val(),
                dietaryPreferences: $('#dietaryPreferences').val()
            };

            try {
                const response = await fetch('/api/users/profile', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    $('#successMessage').text('Profile updated successfully!').show();
                    $('#errorMessage').hide();
                    setTimeout(() => $('#successMessage').hide(), 3000);
                } else {
                    const error = await response.json();
                    $('#errorMessage').text(error.message || 'Update failed').show();
                }
            } catch (error) {
                $('#errorMessage').text('Network error').show();
            }
        }

        $('#updateBtn').click(updateProfile);
        loadProfile();
    </script>
}