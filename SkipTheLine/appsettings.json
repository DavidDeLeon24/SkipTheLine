{
  // Database connection - uses LocalDB for development
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SkipTheLineDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  // JWT Token Settings - for user authentication
  "JwtSettings": {
    "Secret": "SkipTheLineSuperSecretKey2024AtLeast32CharsLong", // Key used to sign tokens
    "ExpirationDays": 7, // Token expires after 7 days
    "Issuer": "SkipTheLineAPI", // Who issued the token
    "Audience": "SkipTheLineClient" // Who the token is for
  },

  // SMTP Email Settings - Gmail configuration
  "Smtp": {
    "Host": "smtp.gmail.com", // Gmail's SMTP server
    "Port": 587, // TLS port for secure email
    "Username": "", // Sender email address
    "Password": "", // Gmail App Password (not regular password)
    "FromEmail": "j", // From address
    "FromName": "SkipTheLine" // Display name for emails
  },

  // Logging Configuration
  "Logging": {
    "LogLevel": {
      "Default": "Information", // Default log level
      "Microsoft.AspNetCore": "Warning", // Less verbose ASP.NET logs
      "SkipTheLine.Services": "Debug" // Detailed logs for email services
    }
  },

  // Allow any host to access the API (for development)
  "AllowedHosts": "*"
}
